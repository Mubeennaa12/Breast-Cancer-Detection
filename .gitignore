# pyenv
#   For a library or app, you might want to share your .python-version.
#   See https://github.com/pyenv/pyenv/blob/master/COMMANDS.md#pyenv-version
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if platform-specific dependencies or sub-dependencies
#   are present, keeping Pipfile.lock might cause issues.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions of dependencies
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains specific versions of dependencies
# pdm.lock
#   pdm local configuration
.pdm-python.path
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

